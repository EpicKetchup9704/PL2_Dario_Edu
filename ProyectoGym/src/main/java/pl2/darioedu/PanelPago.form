    <Component class="javax.swing.JLabel" name="jLabel4">
      <Properties>
        <Property name="text" type="java.lang.String" value="&lt;html&gt;&lt;div style=&apos;text-align: left; font-family: sans-serif;&apos;&gt;&#xa;        &lt;b&gt;\ud83d\udc51 Ventaja Exclusiva:&lt;/b&gt;&lt;br&gt;&lt;br&gt;&#xa;        Siendo &lt;font color=&apos;#FF8C00&apos;&gt;&lt;b&gt;Socio VIP&lt;/b&gt;&lt;/font&gt;, tendr&#xe1;s un &lt;font color=&apos;green&apos;&gt;&lt;b&gt;10% de descuento&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&#xa;        en la reserva de todas las actividades del centro.&lt;br&gt;&lt;br&gt;&#xa;        &lt;font color=&apos;#555555&apos;&gt;&lt;i&gt;Si eres alguien activo en busca de apuntarte a todo,&lt;br&gt;&#xa;        &#xa1;esta es tu oportunidad!&lt;/i&gt;&lt;/font&gt;&lt;/div&gt;&lt;/html&gt;" containsInvalidXMLChars="true"/>
      </Properties>
    </Component>
